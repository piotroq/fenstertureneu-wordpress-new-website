#. Plugin Name of the plugin
#: aioseo-addon.php
msgid "AIOSEO - Template Addon (FOR DEVELOPMENT PURPOSES ONLY)"
msgstr "AIOSEO – dodatek szablonów (WYŁĄCZNIE DO CELÓW ROZWOJOWYCH)"

#. Plugin URI of the plugin
#. Author URI of the plugin
#: aioseo-addon.php
msgid "https://aioseo.com"
msgstr "https://aioseo.com"

#. Description of the plugin
#: aioseo-addon.php
msgid "Extends the main plugin."
msgstr "Rozszerza możliwości wtyczki głównej."

#. Author of the plugin
#: aioseo-addon.php
msgid "All in One SEO Team"
msgstr "Zespół All in One SEO"

#: app/Addon.php:99
msgid "Plugin is missing required dependencies. Please contact support for more information."
msgstr "Wtyczce brakuje wymaganych zależności. Aby uzyskać więcej informacji, skontaktuj się z zespołem pomocy technicznej."

#. Translators: 1 - Opening link tag, 2 - Closing link tag.
#: extend/init.php:160
#, php-format
msgid "Your site is running an outdated version of PHP that is no longer supported and is not compatible with the following addons (%1$sRead more%2$s for additional information):"
msgstr "Twoja witryna korzysta z nieaktualnej wersji języka PHP, która już nie jest obsługiwana i jest niezgodna z następującymi dodatkami (%1$skliknij%2$s, aby uzyskać więcej informacji):"

#. Translators: 1 - "All in One SEO 4.0.0".
#: extend/init.php:167
#, php-format
msgid "The following addons cannot be used, because they require an update to work with %1$s:"
msgstr "Nie można użyć następujących dodatków, ponieważ do ich działania z wtyczką %1$s jest wymagana aktualizacja:"

#. Translators: 1 - "All in One SEO", 2 - Opening HTML link tag, 3 - Closing HTML link tag.
#: extend/init.php:173
#, php-format
msgid "The following addons cannot be used, because they require an active license for %1$s. Your license is missing or has expired. To verify your subscription, please %2$svisit our website%3$s."
msgstr "Nie można używać poniższych dodatków, ponieważ wymagają one aktywnej licencji wtyczki %1$s. Brakuje ci licencji lub licencja wygasła. Aby zweryfikować subskrypcję, %2$sprzejdź do naszej witryny internetowej%3$s."

#. Translators: 1 - "All in One SEO 4.0.0".
#: extend/init.php:181
#, php-format
msgid "The following addons cannot be used, because they require %1$s or later to work:"
msgstr "Nie można użyć następujących dodatków, ponieważ do ich działania jest wymagana wtyczka %1$s lub nowsza:"

#. Translators: 1 - Opening HTML link tag, 2 - Closing HTML link tag.
#: extend/init.php:187
#, php-format
msgid "The following addons cannot be used, because your plan has expired. To renew your subscription, please %1$svisit our website%2$s."
msgstr "Nie można używać poniższych dodatków, ponieważ Twój plan wygasł. Aby odnowić subskrypcję, %1$sprzejdź do naszej witryny internetowej%2$s."

#: extend/init.php:201
msgid "Unlicensed"
msgstr "Bez licencji"

#. Translators: 1 - The current plan name, 2 - Opening HTML link tag, 3 - Closing HTML link tag.
#: extend/init.php:207
#, php-format
msgid "The following addons cannot be used, because your plan level %1$s does not include access to these addons. To upgrade your subscription, please %2$svisit our website%3$s."
msgstr "Nie można używać poniższych dodatków, ponieważ twój plan %1$s nie obejmuje dostępu do nich. Aby ulepszyć swoją subskrypcję, %2$sodwiedź naszą witrynę%3$s."

#. Translators: 1 - "AIOSEO Pro"
#: extend/init.php:459
#, php-format
msgid "Enable the %1$s plugin to manage auto-updates"
msgstr "Włącz wtyczkę %1$s, aby zarządzać automatycznymi aktualizacjami"
